        }
        function syncFromLAB() {
            const rgb = labToRgb(Math.max(0, Math.min(100, parseInt(inputs.labL.value, 10)||0)), Math.max(-128, Math.min(127, parseInt(inputs.labA.value, 10)||0)), Math.max(-128, Math.min(127, parseInt(inputs.labB.value, 10)||0)));
            const hsv = rgbToHsv(rgb.r, rgb.g, rgb.b);
            if (hsv.s !== 0 && hsv.v !== 0) stateH = hsv.h; stateS = hsv.s; stateV = hsv.v; renderFromState();
        }
        function syncFromWheelBri() {
            stateV = Math.max(0, Math.min(100, parseInt(wheelBriSlider.value, 10)||0)) / 100; renderFromState();
        }

        // --- Interaction Drag Physics ---
        
        spectrumHueSlider.addEventListener('input', (e) => { stateH = parseFloat(e.target.value); renderFromState(); });
        let isDraggingField = false;
        function updateFieldFromPointer(e) {
            const rect = colorField.getBoundingClientRect(); const clientX = e.touches ? e.touches[0].clientX : e.clientX; const clientY = e.touches ? e.touches[0].clientY : e.clientY;
            stateS = Math.max(0, Math.min(1, (clientX - rect.left) / rect.width)); stateV = 1 - Math.max(0, Math.min(1, (clientY - rect.top) / rect.height)); renderFromState();
        }
        colorField.addEventListener('mousedown', (e) => { isDraggingField = true; updateFieldFromPointer(e); }); colorField.addEventListener('touchstart', (e) => { isDraggingField = true; updateFieldFromPointer(e); e.preventDefault(); }, {passive: false});
        
        wheelBriSlider.addEventListener('input', syncFromWheelBri);
        let isDraggingWheel = false;
        function updateWheelFromPointer(e) {
            const rect = colorWheel.getBoundingClientRect();
            const clientX = e.touches ? e.touches[0].clientX : e.clientX;
            const clientY = e.touches ? e.touches[0].clientY : e.clientY;
            
            const centerX = rect.left + rect.width / 2;
            const centerY = rect.top + rect.height / 2;
            const dx = clientX - centerX;
            const dy = clientY - centerY;
            
            let angle = Math.atan2(dy, dx) * 180 / Math.PI;
            if (angle < 0) angle += 360;
            
            const radius = Math.sqrt(dx*dx + dy*dy);
            const maxRadius = rect.width / 2;
            
            stateH = angle;
            stateS = Math.min(1, radius / maxRadius);
            renderFromState();
        }
        colorWheel.addEventListener('mousedown', (e) => { isDraggingWheel = true; updateWheelFromPointer(e); }); colorWheel.addEventListener('touchstart', (e) => { isDraggingWheel = true; updateWheelFromPointer(e); e.preventDefault(); }, {passive: false});

        window.addEventListener('mousemove', (e) => { if(isDraggingField) updateFieldFromPointer(e); if(isDraggingWheel) updateWheelFromPointer(e); }); 
        window.addEventListener('touchmove', (e) => { if(isDraggingField) updateFieldFromPointer(e); if(isDraggingWheel) updateWheelFromPointer(e); }, {passive: false});
        window.addEventListener('mouseup', () => { isDraggingField = false; isDraggingWheel = false; }); 
        window.addEventListener('touchend', () => { isDraggingField = false; isDraggingWheel = false; });

        // Logic Generators
        function bindChannel(inputEl, sliderEl, syncMethod, maxVal, minVal = 0) {
            sliderEl.addEventListener('input', (e) => { inputEl.value = e.target.value; syncMethod(); });
            inputEl.addEventListener('input', (e) => { let v = parseInt(e.target.value, 10); if (!isNaN(v)) { sliderEl.value = Math.max(minVal, Math.min(maxVal, v)); syncMethod(); } });
            inputEl.addEventListener('change', (e) => { let v = parseInt(e.target.value, 10); if (isNaN(v)) v = minVal; if (v < minVal) v = minVal; if (v > maxVal) v = maxVal; e.target.value = v; sliderEl.value = v; syncMethod(); });
        }

