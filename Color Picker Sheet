        bindChannel(inputs.hslH, sliders.hslH, syncFromHSL, 360); bindChannel(inputs.hslS, sliders.hslS, syncFromHSL, 100); bindChannel(inputs.hslL, sliders.hslL, syncFromHSL, 100);
