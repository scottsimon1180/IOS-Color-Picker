        // --- Unified Master State ---
        let stateH = 0, stateS = 0.77, stateV = 1; 

        // DOM Maps
        const colorField = document.getElementById('colorField'); const fieldReticle = document.getElementById('fieldReticle'); const spectrumHueSlider = document.getElementById('spectrumHueSlider');
        const colorWheel = document.getElementById('colorWheel'); const wheelReticle = document.getElementById('wheelReticle'); const wheelDarken = document.getElementById('wheelDarken'); const wheelBriSlider = document.getElementById('wheelBriSlider');
        
        const inputs = {
            red: document.getElementById('inputRed'), green: document.getElementById('inputGreen'), blue: document.getElementById('inputBlue'),
            hsbH: document.getElementById('inputHue'), hsbS: document.getElementById('inputSat'), hsbB: document.getElementById('inputBri'),
            hslH: document.getElementById('inputHslHue'), hslS: document.getElementById('inputHslSat'), hslL: document.getElementById('inputHslLum'),
            labL: document.getElementById('inputLabL'), labA: document.getElementById('inputLabA'), labB: document.getElementById('inputLabB')
