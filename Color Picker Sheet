        }
        function syncFromHSB() {
            stateH = Math.max(0, Math.min(360, parseInt(inputs.hsbH.value, 10)||0)); stateS = Math.max(0, Math.min(100, parseInt(inputs.hsbS.value, 10)||0)) / 100; stateV = Math.max(0, Math.min(100, parseInt(inputs.hsbB.value, 10)||0)) / 100; renderFromState();
        }
        function syncFromHSL() {
            const hsv = hslToHsv(Math.max(0, Math.min(360, parseInt(inputs.hslH.value, 10)||0)), Math.max(0, Math.min(100, parseInt(inputs.hslS.value, 10)||0)) / 100, Math.max(0, Math.min(100, parseInt(inputs.hslL.value, 10)||0)) / 100);
