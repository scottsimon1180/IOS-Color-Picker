        document.querySelectorAll('.nudge-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const targetInput = document.getElementById(btn.getAttribute('data-target'));
                const step = parseInt(btn.getAttribute('data-step'), 10);
                const minAttr = targetInput.getAttribute('min'); const minBoundary = minAttr !== null ? parseInt(minAttr, 10) : 0;
                const maxAttr = targetInput.getAttribute('max'); const maxBoundary = maxAttr !== null ? parseInt(maxAttr, 10) : 255;
                let current = parseInt(targetInput.value, 10); if (isNaN(current)) current = 0;
                targetInput.value = Math.max(minBoundary, Math.min(maxBoundary, current + step));
