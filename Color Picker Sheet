        const sliders = {
            red: document.getElementById('sliderRed'), green: document.getElementById('sliderGreen'), blue: document.getElementById('sliderBlue'),
            hsbH: document.getElementById('sliderHue'), hsbS: document.getElementById('sliderSat'), hsbB: document.getElementById('sliderBri'),
            hslH: document.getElementById('sliderHslHue'), hslS: document.getElementById('sliderHslSat'), hslL: document.getElementById('sliderHslLum'),
            labL: document.getElementById('sliderLabL'), labA: document.getElementById('sliderLabA'), labB: document.getElementById('sliderLabB')
        };

        // Pipeline 1: Push Truth to all UI Elements
        function renderFromState() {
            const rgb = hsvToRgb(stateH, stateS, stateV);
            const pureRgb = hsvToRgb(stateH, 1, 1);
            const hsl = hsvToHsl(stateH, stateS, stateV);
            const lab = rgbToLab(rgb.r, rgb.g, rgb.b);
            
            document.documentElement.style.setProperty('--pure-hue', `rgb(${pureRgb.r}, ${pureRgb.g}, ${pureRgb.b})`);
            document.documentElement.style.setProperty('--mixed-color', `rgb(${rgb.r}, ${rgb.g}, ${rgb.b})`);

            // Tab 1: Wheel Updates
            wheelBriSlider.value = Math.round(stateV * 100);
            const briEndRgb = hsvToRgb(stateH, stateS, 1);
            wheelBriSlider.style.setProperty('--bri-end', `rgb(${briEndRgb.r}, ${briEndRgb.g}, ${briEndRgb.b})`);
            wheelDarken.style.opacity = 1 - stateV;
            const angleRad = stateH * Math.PI / 180;
            const reticleX = 50 + (stateS * 50 * Math.cos(angleRad));
            const reticleY = 50 + (stateS * 50 * Math.sin(angleRad));
            wheelReticle.style.left = `${reticleX}%`;
            wheelReticle.style.top = `${reticleY}%`;

            // Tab 2: Spectrum Updates
            spectrumHueSlider.value = stateH; fieldReticle.style.left = `${stateS * 100}%`; fieldReticle.style.top = `${(1 - stateV) * 100}%`;

            // Tab 3: RGB Updates
            inputs.red.value = rgb.r; sliders.red.value = rgb.r; inputs.green.value = rgb.g; sliders.green.value = rgb.g; inputs.blue.value = rgb.b; sliders.blue.value = rgb.b;
            sliders.red.style.setProperty('--track-start', `rgb(0, ${rgb.g}, ${rgb.b})`); sliders.red.style.setProperty('--track-end', `rgb(255, ${rgb.g}, ${rgb.b})`);
            sliders.green.style.setProperty('--track-start', `rgb(${rgb.r}, 0, ${rgb.b})`); sliders.green.style.setProperty('--track-end', `rgb(${rgb.r}, 255, ${rgb.b})`);
            sliders.blue.style.setProperty('--track-start', `rgb(${rgb.r}, ${rgb.g}, 0)`); sliders.blue.style.setProperty('--track-end', `rgb(${rgb.r}, ${rgb.g}, 255)`);

            // Tab 4: HSB Updates
            inputs.hsbH.value = Math.round(stateH); sliders.hsbH.value = Math.round(stateH);
            inputs.hsbS.value = Math.round(stateS * 100); sliders.hsbS.value = Math.round(stateS * 100);
            inputs.hsbB.value = Math.round(stateV * 100); sliders.hsbB.value = Math.round(stateV * 100);
            const satStartRgb = hsvToRgb(stateH, 0, stateV); const satEndRgb = hsvToRgb(stateH, 1, stateV);
            sliders.hsbS.style.setProperty('--sat-start', `rgb(${satStartRgb.r}, ${satStartRgb.g}, ${satStartRgb.b})`); sliders.hsbS.style.setProperty('--sat-end', `rgb(${satEndRgb.r}, ${satEndRgb.g}, ${satEndRgb.b})`);
            sliders.hsbB.style.setProperty('--bri-end', `rgb(${briEndRgb.r}, ${briEndRgb.g}, ${briEndRgb.b})`);

            // Tab 5: HSL Updates
            inputs.hslH.value = Math.round(stateH); sliders.hslH.value = Math.round(stateH);
            inputs.hslS.value = Math.round(hsl.s * 100); sliders.hslS.value = Math.round(hsl.s * 100);
            inputs.hslL.value = Math.round(hsl.l * 100); sliders.hslL.value = Math.round(hsl.l * 100);
