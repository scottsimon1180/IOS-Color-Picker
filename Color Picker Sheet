            sliders.hslS.style.setProperty('--hsl-sat-start', `rgb(${hslSatStartRgb.r}, ${hslSatStartRgb.g}, ${hslSatStartRgb.b})`); sliders.hslS.style.setProperty('--hsl-sat-end', `rgb(${hslSatEndRgb.r}, ${hslSatEndRgb.g}, ${hslSatEndRgb.b})`);
            sliders.hslL.style.setProperty('--track-start', '#000000'); sliders.hslL.style.setProperty('--track-mid', `rgb(${hslLumMidRgb.r}, ${hslLumMidRgb.g}, ${hslLumMidRgb.b})`); sliders.hslL.style.setProperty('--track-end', '#ffffff');

